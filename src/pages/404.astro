---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Room Not Found"
  description="This room doesn't seem to exist in the museum."
>
  <div class="not-found">

    <div class="not-found__postmark" aria-hidden="true">
      <div class="not-found__circle not-found__circle--outer"></div>
      <div class="not-found__circle not-found__circle--inner"></div>
      <span class="not-found__code">404</span>
    </div>

    <h1 class="not-found__title">Room Not Found</h1>

    <p class="not-found__message">
      This door doesn't lead anywhere in the museum.<br />
      Perhaps it was moved, or perhaps it was never built.
    </p>

    <a href="/" class="not-found__return">
      Return to the entrance
    </a>

  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem;
    gap: 1.5rem;
  }

  /* Stacked concentric circles — like a wax seal impression */
  .not-found__postmark {
    position: relative;
    width: 100px;
    height: 100px;
    margin-bottom: 1rem;
  }

  .not-found__circle {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid theme('colors.vellum');
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }

  .not-found__circle--outer { width: 100px; height: 100px; }
  .not-found__circle--inner { width: 72px;  height: 72px; }

  .not-found__code {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: theme('fontFamily.mono');
    font-size: 1rem;
    letter-spacing: 0.14em;
    color: theme('colors.dust');
  }

  .not-found__title {
    font-family: theme('fontFamily.serif');
    font-size: 2rem;
    font-weight: 400;
    color: theme('colors.charcoal');
    letter-spacing: theme('letterSpacing.title');
  }

  .not-found__message {
    font-family: theme('fontFamily.serif');
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.75;
    color: theme('colors.sepia');
    max-width: 36ch;
  }

  .not-found__return {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: theme('colors.dust');
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .not-found__return:hover { color: theme('colors.postmark'); }
</style>
