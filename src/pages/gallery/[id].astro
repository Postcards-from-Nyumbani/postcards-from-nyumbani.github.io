---
// src/pages/gallery/[id].astro
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';
import { formatPostmark, ROOMS } from '../../lib/collections';

// 1. Tell Astro which URLs to generate
export async function getStaticPaths() {
  // Grab all published gallery items
  const galleryEntries = await getCollection('gallery', ({ data }) => {
    return data.status === 'published';
  });

  // Create a route for each item's ID
  return galleryEntries.map(post => ({
    params: { id: post.id }, // This becomes the URL
    props: { post },         // This passes the data to the page below
  }));
}

// 2. Grab the specific post for the current URL
const { post } = Astro.props;

// 3. Render the Markdown into HTML
const { Content } = await render(post);

// Get the specific room styling
const roomDetails = ROOMS['gallery'];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.data.title} | {roomDetails.label}</title>
  </head>
  
  <body class="bg-stone-100 text-stone-900 min-h-screen p-8 md:p-16">
    <div class="max-w-3xl mx-auto">
      
      <a href="/" class="text-xs uppercase tracking-widest text-stone-500 hover:text-stone-900 transition-colors mb-12 inline-block">
        &larr; Back to the Main Hall
      </a>

      <article>
        
        <header class="mb-12 border-b border-stone-300 pb-8">
          <h1 class="text-4xl md:text-5xl font-serif text-stone-800 mb-4">
            {post.data.title}
          </h1>
          
          <div class="flex items-center gap-3 text-xs tracking-widest uppercase">
            <time class="text-stone-500">{formatPostmark(post.data.date)}</time>
            <span class="text-stone-300">|</span>
            <span style={`color: ${roomDetails.colour}`}>{roomDetails.label}</span>
          </div>
          
          {(post.data.medium || post.data.dimensions) && (
            <div class="mt-6 text-sm text-stone-500 italic">
              {post.data.medium && <span>{post.data.medium}</span>}
              {post.data.medium && post.data.dimensions && <span>, </span>}
              {post.data.dimensions && <span>{post.data.dimensions}</span>}
            </div>
          )}
        </header>

        <div class="prose prose-stone prose-lg md:prose-xl max-w-none prose-headings:font-serif prose-a:text-sienna hover:prose-a:text-stone-900">
          <Content />
        </div>
        
      </article>

    </div>
  </body>
</html>